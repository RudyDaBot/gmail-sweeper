# Comma-separated labels for each Gmail account to sweep (e.g. personal,academic).
# Each account, by position in this list, needs its own OAuth client file in
# the project root: the 1st account -> credentials1.json, the 2nd ->
# credentials2.json, etc. Each also gets its own token file (token_<label>.json),
# created the first time you authenticate that account in the browser. The
# real email address is read from the account automatically after sign-in —
# these labels are only used to keep separate accounts' files apart.
# Leave as "default" if you only sweep one account (uses credentials1.json).
GMAIL_ACCOUNTS=personal,academic

# Comma-separated labels (from GMAIL_ACCOUNTS above) that should skip both
# the date cutoff and the bulk-mail filter entirely -- every unread message
# is fetched every run. Leave empty to apply the normal limits everywhere.
GMAIL_UNLIMITED_ACCOUNTS=

# Comma-separated labels that keep the date cutoff but skip just the
# bulk-mail filter (marketing/automated mail included, still only after
# the cutoff). Accounts already in GMAIL_UNLIMITED_ACCOUNTS don't need
# to be listed here too.
GMAIL_NO_BULK_FILTER_ACCOUNTS=

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
